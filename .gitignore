.gitignore

# Ignore Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.

*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/

# Rider
.idea/

# Visual Studio Code
.vscode/

# NuGet Packages
*.nupkg

# Windows Installer files
*.msi
*.msm
